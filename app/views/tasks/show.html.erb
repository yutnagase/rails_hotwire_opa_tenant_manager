<h2><%= @task.name %></h2>
<p><%= link_to "← Back to Tasks", project_tasks_path(@project) %></p>

<dl style="line-height: 2;">
  <dt><strong>Project</strong></dt>
  <dd><%= @project.name %></dd>

  <dt><strong>Assignee</strong></dt>
  <dd><%= @task.user&.name || "Unassigned" %></dd>

  <dt><strong>Status</strong></dt>
  <dd>
    <%= turbo_frame_tag "task_status" do %>
      <% if can?("update", "task") %>
        <%= form_with model: [@project, @task], method: :patch do |f| %>
          <%= f.select :status,
                Task::STATUSES.map { |s| [s.capitalize, s] },
                {},
                onchange: "this.form.requestSubmit()",
                style: "padding: 4px;" %>
        <% end %>
      <% else %>
        <%= @task.status.capitalize %>
      <% end %>
    <% end %>
  </dd>
</dl>

<% if can?("update", "task") %>
  <p><%= link_to "Edit", edit_project_task_path(@project, @task) %></p>
<% end %>
<% if can?("delete", "task") %>
  <p>
    <%= button_to "Delete", project_task_path(@project, @task), method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          style: "background: none; border: none; color: red; cursor: pointer; padding: 0;" %>
  </p>
<% end %>
