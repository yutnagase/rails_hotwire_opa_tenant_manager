<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-gray-800"><%= @project.name %> <span class="text-gray-400 font-normal">/ Tasks</span></h2>
  <% if can?("create", "task") %>
    <%= link_to new_project_task_path(@project), class: "inline-flex items-center gap-1 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Task
    <% end %>
  <% end %>
</div>

<% if @tasks.any? %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Task</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Assignee</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @tasks.each do |task| %>
          <%= render partial: "tasks/task", locals: { task: task, project: @project } %>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-12 text-gray-500">
    <p>No tasks yet.</p>
  </div>
<% end %>
