<div class="flex items-center justify-center min-h-[60vh]">
  <div class="w-full max-w-sm bg-white rounded-lg shadow-md p-8">
    <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">Sign in</h2>

    <% if @auth0_configured %>
      <div class="text-center">
        <%= button_to "Sign in with Auth0", user_auth0_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "w-full px-4 py-3 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 transition cursor-pointer" %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 text-center mb-4">Select a user to sign in (development mode)</p>
      <div class="space-y-3">
        <% @users.each do |user| %>
          <%= button_to "#{user.name} (#{user.role})", dev_session_path, params: { user_id: user.id }, method: :post, class: "w-full px-4 py-2 bg-gray-100 text-gray-800 font-medium rounded-md border border-gray-300 hover:bg-indigo-50 hover:border-indigo-300 transition cursor-pointer" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
